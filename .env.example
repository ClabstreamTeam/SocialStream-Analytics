# Environment Variables for Clabstream Analytics
# Copy this file to .env.local and fill in your actual API keys

# Apify API Token - Get from https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# OpenRouter API Key - Get from https://openrouter.ai/keys
OPENROUTER_KEY=your_openrouter_key_here</content>
<parameter name="filePath">.env.example